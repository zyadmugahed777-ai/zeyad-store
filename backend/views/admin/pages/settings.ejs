<%- include('../../partials/head', { title }) %>
<%- include('../../partials/sidebar', { active }) %>
<main class="admin-main">
  <%- include('../../partials/topbar') %>
  
  <div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="page-title"><%= title %></h1>
      </div>
      <div class="admin-header-actions">
        <a href="/admin/pages" class="btn btn-outline">
          <span class="material-symbols-rounded">arrow_forward</span>
          العودة للقائمة
        </a>
      </div>
    </div>

    <form action="/admin/pages/<%= cmsPage.id %>/settings" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <div class="glass-card mb-4" style="max-width: 800px; margin: 0 auto;">
        
        <div class="form-group">
          <label class="form-label">عنوان الصفحة (عربي) <span class="text-danger">*</span></label>
          <input type="text" name="title_ar" class="form-control" value="<%= cmsPage.title_ar %>" required>
        </div>
        
        <div class="form-group mt-3">
          <label class="form-label">عنوان الصفحة (إنجليزي)</label>
          <input type="text" name="title_en" class="form-control" value="<%= cmsPage.title_en || '' %>" dir="ltr">
        </div>

        <div class="form-group mt-3">
          <label class="form-label">الرابط (Slug)</label>
          <input type="text" class="form-control" value="<%= cmsPage.slug %>" disabled dir="ltr">
          <small class="text-muted d-block mt-1">رابط الصفحة ثابت ولا يمكن تغييره</small>
        </div>

        <div class="form-group mt-3">
          <label class="form-label">النوع</label>
          <input type="text" class="form-control" value="<%= cmsPage.page_type %>" disabled dir="ltr">
        </div>

        <div class="form-group mt-4" style="background: var(--bg-tertiary); padding: 16px; border-radius: 8px;">
          <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
            <input type="checkbox" name="is_active" <%= cmsPage.is_active ? 'checked' : '' %> style="width: 20px; height: 20px;">
            <span style="font-weight: 600;">الصفحة نشطة ومتاحة للزوار</span>
          </label>
        </div>

        <div class="d-flex justify-content-end mt-4">
          <button type="submit" class="btn btn-primary" style="padding: 12px 32px; font-size: 16px;">
            <span class="material-symbols-rounded">save</span>
            حفظ الإعدادات
          </button>
        </div>
      </div>
    </form>
  </div>
</main>
  <script src="/search-manager.js"></script>\n  <script src="/wishlist-manager.js"></script>\n</body>
</html>
