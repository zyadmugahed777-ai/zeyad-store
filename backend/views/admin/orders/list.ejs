<%- include('../../partials/head', { title }) %>
<%- include('../../partials/sidebar', { active }) %>
<main class="admin-main">
  <%- include('../../partials/topbar') %>
  <div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="page-title"><%= title %></h1>
    </div>

    <div class="glass-card mb-4">
      <form action="/admin/orders" method="GET" class="d-flex gap-3 align-items-center">
        <div style="flex: 1;">
          <input type="text" name="q" class="form-control" placeholder="البحث برقم الطلب أو الهاتف..." value="<%= search %>">
        </div>
        <div style="width: 200px;">
          <select name="status" class="form-control">
            <option value="">كل الحالات</option>
            <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>في الانتظار</option>
            <option value="confirmed" <%= status === 'confirmed' ? 'selected' : '' %>>تم التأكيد</option>
            <option value="processing" <%= status === 'processing' ? 'selected' : '' %>>قيد التجهيز</option>
            <option value="shipped" <%= status === 'shipped' ? 'selected' : '' %>>تم الشحن</option>
            <option value="delivered" <%= status === 'delivered' ? 'selected' : '' %>>تم التوصيل</option>
            <option value="cancelled" <%= status === 'cancelled' ? 'selected' : '' %>>ملغي</option>
          </select>
        </div>
        <button type="submit" class="btn btn-accent">
          <span class="material-symbols-rounded">search</span> بحث
        </button>
        <% if(search || status) { %>
          <a href="/admin/orders" class="btn btn-outline">إلغاء</a>
        <% } %>
      </form>
    </div>

    <div class="glass-card">
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>رقم الطلب</th>
              <th>العميل</th>
              <th>الهاتف</th>
              <th>التاريخ</th>
              <th>الإجمالي</th>
              <th class="text-center">الحالة</th>
              <th class="text-center">إجراءات</th>
            </tr>
          </thead>
          <tbody>
            <% if (orders.length === 0) { %>
              <tr><td colspan="7" class="text-center py-5">لا يوجد طلبات.</td></tr>
            <% } %>
            <% orders.forEach(o => { %>
              <tr>
                <td dir="ltr"><code><%= o.order_id %></code></td>
                <td><strong><%= o.first_name %></strong></td>
                <td dir="ltr"><%= o.phone %></td>
                <td><%= helpers.formatDateTime(o.created_at) %></td>
                <td><strong><%= helpers.formatPrice(o.total) %></strong></td>
                <td class="text-center">
                  <span class="badge" style="background-color: <%= helpers.statusColor(o.status) %>; color: white">
                    <%= helpers.statusLabel(o.status) %>
                  </span>
                </td>
                <td class="text-center">
                  <a href="/admin/orders/<%= o.id %>" class="btn-icon" title="عرض التفاصيل">
                    <span class="material-symbols-rounded">visibility</span>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-between align-items-center mt-4">
          <div class="text-muted" style="font-size: 13px;">إجمالي الطلبات: <%= totalItems %></div>
          <div class="d-flex gap-2">
            <% if (page > 1) { %>
              <a href="?page=<%= page - 1 %>&q=<%= search %>&status=<%= status %>" class="btn btn-outline">السابق</a>
            <% } %>
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="?page=<%= i %>&q=<%= search %>&status=<%= status %>" class="btn <%= page === i ? 'btn-primary' : 'btn-outline' %>"><%= i %></a>
            <% } %>
            <% if (page < totalPages) { %>
              <a href="?page=<%= page + 1 %>&q=<%= search %>&status=<%= status %>" class="btn btn-outline">التالي</a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</main>
  <script src="/search-manager.js"></script>\n  <script src="/wishlist-manager.js"></script>\n</body>
</html>