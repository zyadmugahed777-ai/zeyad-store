<%- include('../../partials/head', { title }) %>
<%- include('../../partials/sidebar', { active }) %>
<main class="admin-main">
  <%- include('../../partials/topbar') %>
  
  <div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="page-title"><%= title %></h1>
      </div>
      <div class="admin-header-actions">
        <a href="/admin/departments" class="btn btn-outline">
          <span class="material-symbols-rounded">arrow_forward</span>
          العودة للقائمة
        </a>
      </div>
    </div>

    <form action="<%= department ? '/admin/departments/' + department.id + '/edit' : '/admin/departments/create' %>" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <div class="glass-card mb-4">
        <div class="row" style="display: flex; flex-wrap: wrap; margin: -12px;">
          <!-- Left Column: Primary Details -->
          <div style="flex: 0 0 66.66%; padding: 12px; box-sizing: border-box;">
            <div class="form-group">
              <label class="form-label">الاسم (عربي) <span class="text-danger">*</span></label>
              <input type="text" name="name_ar" class="form-control" value="<%= department ? department.name_ar : '' %>" required oninput="generateSlug(this.value)">
            </div>
            
            <div class="form-group mt-3">
              <label class="form-label">الاسم (إنجليزي)</label>
              <input type="text" name="name_en" class="form-control" value="<%= department ? department.name_en : '' %>" dir="ltr">
            </div>

            <div class="form-group mt-3">
              <label class="form-label">الرابط (Slug) <span class="text-danger">*</span></label>
              <input type="text" name="slug" id="slugInput" class="form-control" value="<%= department ? department.slug : '' %>" required dir="ltr">
              <small class="text-muted d-block mt-1">يستخدم في رابط الصفحة، مثال: home-appliances</small>
            </div>

            <div class="form-group mt-4">
              <label class="form-label">الوصف (عربي)</label>
              <textarea name="description_ar" class="form-control rich-editor" rows="4"><%= department ? department.description_ar : '' %></textarea>
            </div>

            <div class="form-group mt-4">
              <label class="form-label">الوصف (إنجليزي)</label>
              <textarea name="description_en" class="form-control rich-editor" rows="4" dir="ltr"><%= department ? department.description_en : '' %></textarea>
            </div>
          </div>

          <!-- Right Column: Settings & Media -->
          <div style="flex: 0 0 33.33%; padding: 12px; box-sizing: border-box;">
            
            <div class="form-group">
              <label class="form-label">أيقونة (Material Symbols)</label>
              <input type="text" name="icon" class="form-control" value="<%= department ? department.icon : '' %>" dir="ltr" placeholder="مثال: kitchen">
              <small class="text-muted d-block mt-1">
                ابحث عن الأيقونات في <a href="https://fonts.google.com/icons?icon.set=Material+Symbols" target="_blank">Google Fonts</a>
              </small>
            </div>

            <div class="form-group mt-4">
              <label class="form-label">صورة القسم</label>
              <% if (department && department.image) { %>
                <div class="mb-2">
                  <img src="<%= department.image %>" alt="Current Image" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-color);">
                </div>
              <% } %>
              <input type="file" name="image" class="form-control" accept="image/*">
            </div>

            <div class="form-group mt-4">
              <label class="form-label">الترتيب</label>
              <input type="number" name="sort_order" class="form-control" value="<%= department ? department.sort_order : '0' %>" dir="ltr">
            </div>

            <div class="form-group mt-4" style="background: var(--bg-tertiary); padding: 16px; border-radius: 8px;">
              <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <input type="checkbox" name="is_active" <%= (!department || department.is_active) ? 'checked' : '' %> style="width: 20px; height: 20px;">
                <span style="font-weight: 600;">القسم نشط ومرئي للعملاء</span>
              </label>
            </div>

          </div>
        </div>
      </div>

      <div class="d-flex justify-content-end gap-3 mb-5">
        <a href="/admin/departments" class="btn btn-outline">إلغاء</a>
        <button type="submit" class="btn btn-primary" style="padding: 12px 32px; font-size: 16px;">
          <span class="material-symbols-rounded">save</span>
          حفظ التغييرات
        </button>
      </div>

    </form>
  </div>
</main>

<script>
  function generateSlug(text) {
    if (document.getElementById('slugInput').value && '<%= department ? "true" : "" %>' === 'true') {
      return; // Do not auto-generate if editing an existing record
    }
    const slug = text.toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_-]+/g, '-')
      .replace(/^-+|-+$/g, '');
    
    // Arabic letters are stripped by the regex above. 
    // Usually for Arabic, we use a library to transliterate, or just let the user enter English slugs.
    // For now, if the generated slug is empty (because it was all Arabic), we just do nothing.
    if(slug) {
      document.getElementById('slugInput').value = slug;
    }
  }
</script>
  <script src="/search-manager.js"></script>\n  <script src="/wishlist-manager.js"></script>\n</body>
</html>
