<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>خطأ | زياد للأعمال</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
  <link rel="stylesheet" href="/admin-assets/admin.css">
  <style>
    .error-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background-color: var(--light);
      padding: 24px;
      text-align: center;
    }
    .error-card {
      background: var(--white);
      padding: 48px;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      max-width: 600px;
      width: 100%;
    }
    .error-icon {
      font-size: 64px;
      color: var(--danger);
      margin-bottom: 16px;
    }
    .error-code {
      font-size: 24px;
      font-weight: bold;
      color: var(--secondary);
      margin-bottom: 8px;
    }
    .error-message {
      font-size: 18px;
      color: var(--text-main);
      margin-bottom: 24px;
    }
    .error-stack {
      background: #f8fafc;
      padding: 16px;
      border-radius: 8px;
      text-align: left;
      direction: ltr;
      overflow-x: auto;
      font-family: monospace;
      font-size: 12px;
      color: #334155;
      margin-bottom: 24px;
      border: 1px solid var(--border);
    }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="error-card">
      <span class="material-symbols-outlined error-icon">error</span>
      <div class="error-code"><%= typeof status !== 'undefined' ? status : 500 %></div>
      <div class="error-message"><%= typeof message !== 'undefined' ? message : (typeof error !== 'undefined' ? error : 'حدث خطأ داخلي في الخادم') %></div>
      
      <% if (typeof process !== 'undefined' && process.env && process.env.NODE_ENV !== 'production' && typeof stack !== 'undefined') { %>
        <pre class="error-stack"><%= stack %></pre>
      <% } %>
      
      <a href="/admin" class="btn-primary">العودة للوحة التحكم</a>
    </div>
  </div>
  <script src="/search-manager.js"></script>\n  <script src="/wishlist-manager.js"></script>\n</body>
</html>
