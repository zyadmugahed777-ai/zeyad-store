<%- include('../../partials/head', { title }) %>
<%- include('../../partials/sidebar', { active }) %>
<main class="admin-main">
  <%- include('../../partials/topbar') %>
  
  <div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="page-title"><%= title %></h1>
      </div>
      <div class="admin-header-actions">
        <a href="/admin/banners" class="btn btn-outline">
          <span class="material-symbols-rounded">arrow_forward</span>
          العودة للقائمة
        </a>
      </div>
    </div>

    <form action="<%= banner ? '/admin/banners/' + banner.id + '/edit' : '/admin/banners/create' %>" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <div class="row" style="display: flex; flex-wrap: wrap; margin: -12px;">
        <!-- Left Column: Details -->
        <div style="flex: 0 0 66.66%; padding: 12px; box-sizing: border-box;">
          
          <div class="glass-card mb-4">
            <h2 style="font-size: 1.1rem; margin-bottom: 20px; color: var(--primary-color);">النصوص والمحتوى</h2>
            
            <div class="form-group">
              <label class="form-label">العنوان الرئيسي <span class="text-danger">*</span></label>
              <input type="text" name="title" class="form-control" value="<%= banner ? banner.title : '' %>" required>
            </div>
            
            <div class="form-group mt-3">
              <label class="form-label">العنوان الفرعي (Subtitle)</label>
              <input type="text" name="subtitle" class="form-control" value="<%= banner ? banner.subtitle : '' %>">
            </div>

            <div class="form-group mt-3">
              <label class="form-label">النص التفصيلي (إن وجد)</label>
              <textarea name="body" class="form-control" rows="3"><%= banner ? banner.body : '' %></textarea>
            </div>
            
            <div class="row" style="display: flex; flex-wrap: wrap; margin: 0 -8px; margin-top: 16px;">
              <div style="flex: 0 0 50%; padding: 0 8px; box-sizing: border-box;">
                <label class="form-label">نص الزر (CTA)</label>
                <input type="text" name="button_text" class="form-control" value="<%= banner ? banner.button_text : '' %>" placeholder="مثال: تسوق الآن">
              </div>
              <div style="flex: 0 0 50%; padding: 0 8px; box-sizing: border-box;">
                <label class="form-label">رابط الزر (URL)</label>
                <input type="text" name="link" class="form-control" value="<%= banner ? banner.link : '' %>" dir="ltr" placeholder="مثال: /products?category=1">
              </div>
            </div>
          </div>

          <div class="glass-card mb-4">
            <h2 style="font-size: 1.1rem; margin-bottom: 20px; color: var(--primary-color);">صور البنر</h2>
            <p class="text-muted mb-3" style="font-size: 13px;">يرجى رفع صور بجودة عالية (JPG, PNG, WebP). سيتم استخدام الصورة الأساسية للديسكتوب في حال عدم رفع صورة مخصصة.</p>
            
            <div class="form-group">
              <label class="form-label">الصورة الأساسية (تستخدم للكمبيوتر والموبايل إن لم يتم التخصيص)</label>
              <% if (banner && banner.image) { %>
                <div class="mb-2">
                  <img src="<%= banner.image %>" alt="Current Image" style="width: 100%; max-height: 200px; object-fit: contain; border-radius: 8px; border: 1px solid var(--border-color); background: #000;">
                </div>
              <% } %>
              <input type="file" name="image" class="form-control" accept="image/*">
            </div>

            <div class="form-group mt-4">
              <label class="form-label">رابط صورة مخصصة للموبايل (اختياري)</label>
              <input type="text" name="mobile_image" class="form-control" value="<%= banner ? banner.mobile_image : '' %>" dir="ltr" placeholder="أو أدخل رابط صورة مباشرة">
              <small class="text-muted d-block mt-1">إذا ترك فارغاً سيتم استخدام الصورة الأساسية</small>
            </div>
          </div>

        </div>

        <!-- Right Column: Settings -->
        <div style="flex: 0 0 33.33%; padding: 12px; box-sizing: border-box;">
          
          <div class="glass-card mb-4">
            <h2 style="font-size: 1.1rem; margin-bottom: 20px; color: var(--primary-color);">الإعدادات</h2>

            <div class="form-group">
              <label class="form-label">مكان الظهور (Position)</label>
              <select name="position" class="form-control">
                <option value="home_hero" <%= banner && banner.position === 'home_hero' ? 'selected' : '' %>>سلايدر الرئيسية (علوي)</option>
                <option value="home_middle" <%= banner && banner.position === 'home_middle' ? 'selected' : '' %>>الرئيسية (بنر وسط)</option>
                <option value="category_top" <%= banner && banner.position === 'category_top' ? 'selected' : '' %>>أعلى أقسام المنتجات</option>
                <option value="popup" <%= banner && banner.position === 'popup' ? 'selected' : '' %>>نافذة منبثقة (Pop-up)</option>
              </select>
            </div>

            <div class="form-group mt-4">
              <label class="form-label">الحالة</label>
              <select name="status" class="form-control">
                <option value="active" <%= banner && banner.status === 'active' ? 'selected' : '' %>>نشط ومتاح للعملاء</option>
                <option value="hidden" <%= banner && banner.status === 'hidden' ? 'selected' : '' %>>مخفي</option>
                <option value="draft" <%= banner && banner.status === 'draft' ? 'selected' : '' %>>مسودة</option>
              </select>
            </div>

            <div class="form-group mt-4">
              <label class="form-label">تاريخ البداية (اختياري)</label>
              <input type="datetime-local" name="start_date" class="form-control" value="<%= banner && banner.start_date ? banner.start_date.replace(' ', 'T') : '' %>" dir="ltr">
            </div>

            <div class="form-group mt-4">
              <label class="form-label">تاريخ النهاية (اختياري)</label>
              <input type="datetime-local" name="end_date" class="form-control" value="<%= banner && banner.end_date ? banner.end_date.replace(' ', 'T') : '' %>" dir="ltr">
            </div>

            <div class="form-group mt-4">
              <label class="form-label">الترتيب</label>
              <input type="number" name="sort_order" class="form-control" value="<%= banner ? banner.sort_order : '0' %>" dir="ltr">
              <small class="text-muted d-block mt-1">الأقل يظهر أولاً (مثال: 0، 1، 2)</small>
            </div>
            
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-end gap-3 mb-5">
        <a href="/admin/banners" class="btn btn-outline">إلغاء</a>
        <button type="submit" class="btn btn-primary" style="padding: 12px 32px; font-size: 16px;">
          <span class="material-symbols-rounded">save</span>
          حفظ التغييرات
        </button>
      </div>

    </form>
  </div>
</main>
  <script src="/search-manager.js"></script>\n  <script src="/wishlist-manager.js"></script>\n</body>
</html>
